# Local development only. Copy this file to `.env` and edit it:
#
#     cp .env.example .env
#
# `.env` is gitignored; this example is not. These variables are read by
# vite.config.js to configure the local dev server. Nothing here reaches the
# browser: the name has no `VITE_` prefix, so Vite will never inline it into
# the client bundle.

# Port for `npm run dev`. Unset, it defaults to 3000. Set it to 0 to let the OS
# pick any free port. Set it to something that isn't a number and Vite quietly
# falls back to its own default of 5173.
#
# The server refuses to start if the port is taken, so if you change this,
# update `.claude/launch.json` to match.
#
# Named PONG_PORT rather than PORT on purpose: Vite merges the whole ambient
# environment over your .env file, and a stray `export PORT=...` would silently
# win.
PONG_PORT=3000
